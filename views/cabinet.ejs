<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no"/>
  <title>Mon espace</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --yellow: #FFD966;
      --yellow-dark: #FCE27E;
      --gray: #f0f2f5;
      --border: #e4e6ea;
      --text: #1c1e21;
      --muted: #65676b;
      --white: #ffffff;
    }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      background: var(--gray);
      color: var(--text);
      padding: 20px 16px;
      max-width: 480px;
      margin: 0 auto;
    }
    .header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 28px;
    }
    .header h1 { font-size: 22px; font-weight: 700; }
    .logout {
      font-size: 16px; color: var(--muted); text-decoration: none;
      font-weight: 900; line-height: 1;
    }
    .section-title {
      font-size: 13px; font-weight: 600; color: var(--muted);
      text-transform: uppercase; letter-spacing: 0.05em;
      margin-bottom: 14px;
    }
    .course-card {
      background: var(--white);
      border-radius: 18px;
      padding: 20px;
      margin-bottom: 14px;
      box-shadow: 0 2px 12px rgba(0,0,0,0.06);
      text-decoration: none;
      color: var(--text);
      display: block;
      transition: transform 0.15s, box-shadow 0.15s;
    }
    .course-card:active { transform: scale(0.98); }
    .course-title {
      font-size: 17px; font-weight: 700; margin-bottom: 12px;
    }
    .progress-bar-wrap {
      background: #d0d3d8;
      border-radius: 99px;
      height: 8px;
      margin-bottom: 8px;
      overflow: hidden;
    }
    .progress-bar-fill {
      height: 100%;
      background: var(--yellow);
      border-radius: 99px;
      transition: width 0.3s;
    }
    .progress-text {
      font-size: 13px; color: var(--muted);
      display: flex; justify-content: space-between;
    }
    .card-footer {
      margin-top: 14px;
      display: flex; justify-content: flex-end;
    }
    .btn-go {
      background: var(--yellow);
      color: #241c15;
      border: none;
      border-radius: 10px;
      padding: 10px 20px;
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
      font-family: inherit;
    }
  </style>
</head>
<body>
  <div class="header">
    <h1>Bonjour <%= user.name %> 👋</h1>
    <a href="/logout" class="logout">✕</a>
  </div>

  <div class="section-title">Vos cours</div>

  <% courses.forEach(course => { %>
    <%
      const completed = parseInt(course.completed) || 0;
      const total = parseInt(course.total_lessons) || 30;
      const percent = Math.min(100, Math.round((completed / total) * 100));
    %>
    <a href="/cabinet/course/<%= course.id %>" class="course-card">
      <div class="course-title">📚 <%= course.title %></div>
      <div class="progress-bar-wrap">
        <div class="progress-bar-fill" style="width:<%= percent %>%"></div>
      </div>
      <div class="progress-text">
        <span><%= completed %> leçon<%= completed !== 1 ? 's' : '' %> complétée<%= completed !== 1 ? 's' : '' %></span>
        <span><%= percent %>%</span>
      </div>
      <div class="card-footer">
        <button class="btn-go">Accéder au cours →</button>
      </div>
    </a>
  <% }) %>

</body>
</html>